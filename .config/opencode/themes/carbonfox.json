{
    "$schema": "https://opencode.ai/theme.json",
    "defs": {
        "bg": "#161616",
        "bg0": "#111111",
        "bg1": "#161616",
        "bg2": "#1c1c1c",
        "bg3": "#222222",
        "bg4": "#2e2e2e",
        "fg0": "#f8faff",
        "fg1": "#f2f4f8",
        "fg2": "#d9dbe0",
        "fg3": "#b0b2b6",
        "comment": "#6e6f70",
        "sel0": "#2a2a2a",
